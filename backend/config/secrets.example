# Sifat Nazorati — Secret environment variables
# Copy this file to backend/.env and fill in real values.
# NEVER commit the actual .env file to git.

# Google Gemini AI API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_API_KEY_HERE

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/sifat_nazorati

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-this-to-a-random-secret-string

NODE_ENV=development
PORT=3000
